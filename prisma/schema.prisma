generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  password_hash String?
  emailVerified DateTime?
  image         String?
  provider      String?
  accounts      Account[]
  sessions      Session[]
  profile       Profile?
  analysis      Analysis?
  problemProgress UserProblemProgress[]
  projectProgress UserProjectProgress[]
}

model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?  
  access_token       String?  
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?  
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Profile {
  id                  String   @id @default(cuid())
  user_id             String   @unique @map("userId")
  target_role         String?
  resume_url          String?
  skills              String?  // JSON string
  projects            String?  // JSON string
  education           String?  // JSON string
  experience          String?  // JSON string
  onboarding_complete Boolean  @default(false)
  user                User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
}

model Analysis {
  id               String   @id @default(cuid())
  user_id          String   @unique @map("userId")
  readiness_score  Int?
  role_match_score Int?
  roadmap          String?  // JSON string
  recommendations  String?  // JSON string
  user             User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
}

model ProblemBank {
  id               String   @id @default(cuid())
  title            String
  platform         String
  url              String?
  difficulty       String
  topic            String
  subtopic         String?
  role_tags        String   // JSON or comma separated
  estimated_time   Int?     // minutes
  explanation_url  String?
  video_url        String?
  companies        String?
  frequency_score  Int?
  created_at       DateTime @default(now())
  updated_at       DateTime @updatedAt

  userProgress     UserProblemProgress[]
}

model ProjectBank {
  id                  String   @id @default(cuid())
  title               String
  description         String
  difficulty          String
  role_tags           String
  tech_stack          String   // comma separated
  estimated_duration  String
  skills_covered      String   // comma separated
  github_links        String?
  documentation_links String?
  tutorial_links      String?
  architecture_guide  String?
  resume_value_score  Int?
  industry_category   String?
  created_at          DateTime @default(now())
  updated_at          DateTime @updatedAt

  userProgress        UserProjectProgress[]
}

model UserProblemProgress {
  id              String   @id @default(cuid())
  userId          String
  problemId       String
  status          String   // Solved, Attempted, Skipped, Bookmarked
  updated_at      DateTime @updatedAt

  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  problem         ProblemBank @relation(fields: [problemId], references: [id], onDelete: Cascade)

  @@unique([userId, problemId])
}

model UserProjectProgress {
  id              String   @id @default(cuid())
  userId          String
  projectId       String
  status          String   // In Progress, Completed, Bookmarked
  current_phase   Int      @default(1)
  completed_tasks String?  @default("[]")
  updated_at      DateTime @updatedAt

  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  project         ProjectBank @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([userId, projectId])
}
